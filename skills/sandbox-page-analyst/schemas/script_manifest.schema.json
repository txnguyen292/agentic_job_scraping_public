{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["scripts"],
  "properties": {
    "scripts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "purpose"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "inputs": {"type": "array"},
          "outputs": {"type": "array"},
          "sha256": {"type": "string"},
          "workflow_version": {"type": "string"},
          "reference_version": {"type": "string"},
          "reuse": {"type": "string"},
          "validation_result": {"type": "object"}
        }
      }
    }
  }
}
